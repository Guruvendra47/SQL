/*
QUESTION 33 (Very High Probability — NOT EXISTS Pattern)

Tables:

CUSTOMERS
---------
CUSTOMER_ID

ORDERS
------
ORDER_ID
CUSTOMER_ID
ORDER_DATE

👉 Find customers who have placed orders in every year present in the ORDERS table.
*/

-- note : you have to find total year in order table match with client whether he order in all year or not

SELECT 
  CUSTOMER_ID
FROM ORDERS O
GROUP BY CUSTOMER_ID
HAVING 
  COUNT(DISTINCT YEAR(ORDER_DATE)) = (SELECT
  COUNT(DISTINCT YEAR(ORDER_DATE)) AS ct_yr
FROM ORDERS O1);


--with statement

WITH singh AS (
  SELECT COUNT(DISTINCT YEAR(ORDER_DATE)) as yr_count FROM ORDERS
)
SELECT CUSTOMER_ID
FROM ORDERS
GROUP BY CUSTOMER_ID
HAVING COUNT(DISTINCT YEAR(ORDER_DATE)) = (SELECT yr_count FROM singh);

/*
QUESTION 39 (Very High Probability — “At Least One” + “All” Mix)

Table:

ORDERS
-------
CUSTOMER_ID
ORDER_DATE
AMOUNT

👉 Find customers who have placed at least one order every year present in the ORDERS table.
*/

SELECT CUSTOMER_ID
FROM ORDERS
GROUP BY CUSTOMER_ID
HAVING COUNT(DISTINCT YEAR(ORDER_DATE)) = (
    SELECT COUNT(DISTINCT YEAR(ORDER_DATE))
    FROM ORDERS
);

--with cte

WITH TotalYears AS (
    SELECT 
      COUNT(DISTINCT YEAR(ORDER_DATE)) AS total_cnt 
    FROM ORDERS
)
SELECT 
    CUSTOMER_ID
FROM ORDERS, TotalYears
GROUP BY CUSTOMER_ID, total_cnt
HAVING COUNT(DISTINCT YEAR(ORDER_DATE)) = total_cnt;

--QUESTION 9 (Very High Probability — Anti-Join Pattern)
/*
Tables:

CUSTOMERS
---------
CUSTOMER_ID
NAME

ORDERS
------
ORDER_ID
CUSTOMER_ID


👉 Find customers who have never placed an order.
*/

SELECT
  CUSTOMER_ID
FROM CUSTOMERS
EXCEPT  -- Not supported in MySQL (uses MINUS in Oracle)
SELECT
  CUSTOMER_ID
FROM ORDERS;

--(OR)

SELECT 
 C.CUSTOMER_ID,
 C.CUST_NAME
FROM CUSTOMERS C
LEFT JOIN ORDERS O
ON C.CUSTOMER_ID = O.CUSTOMER_ID
WHERE O.CUSTOMER_ID IS NULL
ORDER BY C.CUSTOMER_ID;  ---order by is option data look clean


