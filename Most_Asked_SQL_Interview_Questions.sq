USE ROLE SYSADMIN; 
USE DATABASE DB_SQL_PRACTICE;
USE SCHEMA SM_SQL_PRACTICE;

--Question #1 (VERY COMMON, MIXED)
/*
You have a table:

ORDERS
-------
ORDER_ID
CUSTOMER_ID
ORDER_DATE
AMOUNT


👉 Find customers who have placed at least 2 orders on the same day.
*/

SELECT DISTINCT
  CUSTOMER_ID,
  ORDER_DATE,
  COUNT(ORDER_ID) AS Orders_same_Day
FROM ORDERS
GROUP BY CUSTOMER_ID, ORDER_DATE
HAVING
  COUNT(ORDER_ID) >= 2;

  ---QUESTION 2 (Very High Probability, Mixed Concepts)
/*
Table:

ORDERS
-------
ORDER_ID
CUSTOMER_ID
ORDER_DATE
AMOUNT


👉 Find customers who have placed orders on at least 3 different days.
*/

SELECT
  CUSTOMER_ID,
  COUNT(DISTINCT ORDER_DATE) AS no
FROM ORDERS
GROUP BY CUSTOMER_ID
HAVING
  COUNT(DISTINCT ORDER_DATE) >= 3;


----when interviwer want all the coulmns included in the result
-- Query 1
WITH SINGH AS (
  SELECT CUSTOMER_ID
  FROM ORDERS
  GROUP BY CUSTOMER_ID
  HAVING COUNT(DISTINCT ORDER_DATE) >= 3
)
SELECT *
FROM ORDERS
WHERE CUSTOMER_ID IN (SELECT CUSTOMER_ID FROM SINGH)
ORDER BY CUSTOMER_ID, ORDER_DATE;


--(OR)

-- Query 2
SELECT 
  ORDER_ID, 
  CUSTOMER_ID, 
  ORDER_DATE, 
  AMOUNT
FROM ORDERS O1
WHERE CUSTOMER_ID IN (
    -- This is your original 'Loyalty' logic
    SELECT 
      CUSTOMER_ID
    FROM ORDERS O2
    GROUP BY CUSTOMER_ID
    HAVING 
      COUNT(DISTINCT ORDER_DATE) >= 3
)
ORDER BY CUSTOMER_ID, ORDER_DATE;

/*
QUESTION 21 (Very High Probability — Conditional Aggregation)

Table:

ORDERS
-------
ORDER_ID
CUSTOMER_ID
ORDER_DATE
AMOUNT


👉 Find customers who placed more than 3 orders AND whose total order amount is greater than 200.
*/

SELECT
  CUSTOMER_ID,
  COUNT(ORDER_ID) AS noof,
  SUM(AMOUNT) as totalamt
FROM ORDERS
GROUP BY CUSTOMER_ID
HAVING 
  COUNT(ORDER_ID) > 3 
  AND 
  SUM(AMOUNT) > 200;


--when interviwer want all the coulmns included in the result
with singh as (
SELECT
  CUSTOMER_ID,
  COUNT(ORDER_ID) AS noof,
  SUM(AMOUNT) as totalamt
FROM ORDERS
GROUP BY CUSTOMER_ID
HAVING 
  COUNT(ORDER_ID) > 3 
  AND 
  SUM(AMOUNT) > 200
)
select*
from orders
where CUSTOMER_ID in (select CUSTOMER_ID from sing);


--- QUESTION 10 (Very High Probability — Time Logic + Aggregation)
/*
Table:

ORDERS
-------
ORDER_ID
CUSTOMER_ID
ORDER_DATE
AMOUNT


👉 Find the total sales for each month in 2023.

Remember:
we can use windwos function to get the result but in backside sum will distrubed to all the row
*/
--Some interviewers prefer avoiding YEAR() because it can prevent index usage.

--Safer pattern:

SELECT
  DATE_TRUNC('MONTH', ORDER_DATE) AS MONTH,
  SUM(AMOUNT) AS TOTAL_SALES
FROM ORDERS
WHERE ORDER_DATE >= '2023-01-01'
  AND ORDER_DATE < '2024-01-01'
GROUP BY DATE_TRUNC('MONTH', ORDER_DATE)
ORDER BY MONTH;

-- if interviewer asked you to show all columns then go for windows function

SELECT
 ORDER_ID,
 CUSTOMER_ID,
 ORDER_DATE,
 AMOUNT,
 SUM(AMOUNT) OVER(PARTITION BY MONTH(ORDER_DATE) ORDER BY ORDER_DATE)
FROM ORDERS
WHERE year(ORDER_DATE) = 2023;

--QUESTION-3 (High Probability, Mixed Concepts)
/*
Table:

EMPLOYEE
---------
EMP_ID
NAME
DEPT
SALARY


👉 Find employees whose salary is higher than the average salary of their department.
*/

--mainquery

SELECT 
  EMP_ID,
  NAME,
  DEPT,
  SALARY
FROM EMPLOYEE E1
WHERE SALARY > (---Subquery
SELECT
  AVG(SALARY) AS AVG_SALARY
FROM EMPLOYEE E2
WHERE E1.DEPT = E2.DEPT);


/*
QUESTION 4 (Very High Probability — JOIN + Aggregation)

Tables:

CUSTOMERS
---------
CUSTOMER_ID
NAME

ORDERS
------
ORDER_ID
CUSTOMER_ID
AMOUNT

👉 Find customers whose total order amount is greater than the average total order amount across all customers.
*/

--Method 1 CTE (common table Expression)
WITH SINGH AS (
    SELECT
        CUSTOMER_ID,
        SUM(AMOUNT) AS total_order
    FROM ORDERS
    GROUP BY CUSTOMER_ID
)
SELECT 
  CUSTOMER_ID, 
  total_order
FROM SINGH
WHERE total_order > (
    SELECT 
      AVG(total_order)
    FROM SINGH
);

--method 2 without CTE

SELECT
  CUSTOMER_ID,
  SUM(AMOUNT) AS total_order
FROM ORDERS
GROUP BY CUSTOMER_ID
HAVING 
  SUM(AMOUNT) > (
  SELECT AVG(sub_total) 
  FROM (
    SELECT 
      SUM(AMOUNT) AS sub_total -- 1. We name the sum 'sub_total' here
    FROM ORDERS
    GROUP BY CUSTOMER_ID
  )t  -- 2. We name the whole subquery 'inner_table' here
);


